---
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPreview from '../../components/BlogPreview.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { filterPublishedPosts, sortPostsByDate } from '../../utils/posts';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  const publishedPosts = filterPublishedPosts(posts);
  const sortedPosts = sortPostsByDate(publishedPosts);

  const pageSize = 10;
  const totalPages = Math.ceil(sortedPosts.length / pageSize);
  const paths = [];

  // /blog (page 1)
  paths.push({
    params: { page: undefined },
    props: {
      posts: sortedPosts.slice(0, pageSize),
      currentPage: 1,
      totalPages,
    },
  });

  // /blog/1 → 301 redirect to /blog
  paths.push({
    params: { page: '1' },
    props: { redirect: '/blog' },
  });

  // /blog/2, /blog/3, ...
  for (let i = 2; i <= totalPages; i++) {
    const start = (i - 1) * pageSize;
    paths.push({
      params: { page: String(i) },
      props: {
        posts: sortedPosts.slice(start, start + pageSize),
        currentPage: i,
        totalPages,
      },
    });
  }

  return paths;
};

interface Props {
  redirect?: string;
  posts?: CollectionEntry<'blog'>[];
  currentPage?: number;
  totalPages?: number;
}

const { redirect, posts, currentPage, totalPages } = Astro.props as Props;

if (redirect) {
  return Astro.redirect(redirect, 301);
}
---

<BaseLayout title={`博客列表${currentPage > 1 ? ` - 第 ${currentPage} 页` : ''}`}>
  <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
    博客列表{currentPage > 1 && ` - 第 ${currentPage} 页`}
  </h1>
  <section>
    {posts.map((post: CollectionEntry<'blog'>) => <BlogPreview post={post} />)}
  </section>
  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    baseUrl="/blog/"
  />
</BaseLayout>
